<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="warm_paws_member_action" model="ir.actions.act_window">
        <field name="name">會員與收藏</field>
        <field name="res_model">warm.paws.member</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="warm_paws_member_view_list" model="ir.ui.view">
        <field name="name">warm.paws.member.list</field>
        <field name="model">warm.paws.member</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="city"/>
            </list>
        </field>
    </record>

    <record id="warm_paws_member_view_form" model="ir.ui.view">
        <field name="name">warm.paws.member.form</field>
        <field name="model">warm.paws.member</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="city"/>
                        <field name="password" password="True"/>
                    </group>
                    <field name="favorite_ids" widget="many2many_tags"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
